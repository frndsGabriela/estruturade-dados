#include <stdio.h>

int main() {
    int i, j;
    int n;
    int soma = 0;

    printf("Digite a ordem da matriz: ");
    scanf("%d", &n);

    int matriz[n][n];

    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &matriz[i][j]);
        }
    }

    for(i = 0; i < n; i++) {
        soma += matriz[i][i];
    }

    printf("Soma da diagonal principal: %d\n", soma);

    return 0;
}
