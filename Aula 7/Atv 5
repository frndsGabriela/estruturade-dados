#include <stdio.h>

int main() {
    int i, j;
    int linhas, colunas;

    printf("Digite o numero de linhas: ");
    scanf("%d", &linhas);

    printf("Digite o numero de colunas: ");
    scanf("%d", &colunas);

    int matriz[linhas][colunas];

    for(i = 0; i < linhas; i++) {
        for(j = 0; j < colunas; j++) {
            scanf("%d", &matriz[i][j]);
        }
    }

    int maior = matriz[0][0];
    int linha = 0, coluna = 0;

    for(i = 0; i < linhas; i++) {
        for(j = 0; j < colunas; j++) {
            if(matriz[i][j] > maior) {
                maior = matriz[i][j];
                linha = i;
                coluna = j;
            }
        }
    }

    printf("Maior elemento: %d\n", maior);
    printf("Posicao: linha %d, coluna %d\n", linha, coluna);

    return 0;
}
