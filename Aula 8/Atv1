#include <stdio.h>

int main() {
    int setores, produtos;
    scanf("%d %d", &setores, &produtos);

    int estoque[setores][produtos];

    for(int i = 0; i < setores; i++) {
        for(int j = 0; j < produtos; j++) {
            scanf("%d", &estoque[i][j]);
        }
    }

    for(int i = 0; i < setores; i++) {
        int soma = 0;
        for(int j = 0; j < produtos; j++) {
            soma += estoque[i][j];
        }
        printf("Total setor %d: %d\n", i, soma);
    }

    for(int j = 0; j < produtos; j++) {
        int soma = 0;
        for(int i = 0; i < setores; i++) {
            soma += estoque[i][j];
        }
        printf("Total produto %d: %d\n", j, soma);
    }

    for(int i = 0; i < setores; i++) {
        for(int j = 0; j < produtos; j++) {
            printf("Setor %d Produto %d: %d\n", i, j, estoque[i][j]);
        }
    }

    for(int i = 0; i < setores; i++) {
        for(int j = 0; j < produtos; j++) {
            printf("%d ", estoque[i][j]);
        }
        printf("\n");
    }

    return 0;
}
