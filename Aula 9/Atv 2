#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    int *vet;

    scanf("%d", &n);

    vet = (int*) calloc(n, sizeof(int));

    for(int i = 0; i < n; i++) {
        printf("%d ", vet[i]);
    }
    printf("\n");

    for(int i = 0; i < n; i++) {
        scanf("%d", &vet[i]);
    }

    for(int i = 0; i < n; i++) {
        printf("%d ", vet[i]);
    }

    free(vet);

    return 0;
}
