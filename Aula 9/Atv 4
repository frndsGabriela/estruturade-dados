#include <stdio.h>
#include <stdlib.h>

void alocar(int **vet, int n) {
    *vet = (int*) calloc(n, sizeof(int));
}

int main() {
    int n;
    int *vet;

    scanf("%d", &n);

    alocar(&vet, n);

    for(int i = 0; i < n; i++) {
        scanf("%d", &vet[i]);
    }

    for(int i = 0; i < n; i++) {
        printf("%d ", vet[i]);
    }
    printf("\n");

    int novo;
    scanf("%d", &novo);

    vet = (int*) realloc(vet, novo * sizeof(int));

    for(int i = 0; i < novo; i++) {
        scanf("%d", &vet[i]);
    }

    for(int i = 0; i < novo; i++) {
        printf("%d ", vet[i]);
    }

    free(vet);

    return 0;
}
